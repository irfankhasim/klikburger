# Pilihan — untuk Admin SDK / gcloud Application Default Credentials
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Pilihan — override project (lalai diambil dari .firebaserc)
# FIREBASE_PROJECT_ID=possystem-6907d
# GCLOUD_PROJECT=possystem-6907d

# Emulator (biasanya ditetapkan oleh skrip; jangan set jika guna Cloud)
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
